rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Core Authentication Helpers
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Module: User Profiles & Device State
    // Reason: Users can only modify their own application state and profiles.
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Module: Live SOS & Active Emergency Streams
    // Reason: Anyone authenticated can trigger an SOS. Only the victim, their predefined 
    // trusted responders, or the public heatmap (if flagged public) can read or track the stream.
    match /incidents/{incidentId} {
      allow create: if isAuthenticated();
      allow read, update: if isAuthenticated() && (
        request.auth.uid == resource.data.victimId || 
        request.auth.uid in resource.data.trustedResponders ||
        resource.data.isPublicHeatmap == true
      );
      allow delete: if false; // Incidents cannot be deleted to preserve system integrity
    }

    // Module: Tamper-Proof Evidence Vault
    // Reason: Strict offline-to-online sync rules. Once evidence (audio/video/CCTV notes) 
    // is uploaded, it is permanently locked. It cannot be updated or deleted by anyone, 
    // including the victim, to maintain legal chain-of-custody integrity for courts.
    match /evidence_vault/{vaultId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow update, delete: if false; 
    }

    // Module: Trusted Circles & Volunteer Networks
    // Reason: Users manage their own private network of responders.
    match /trusted_circles/{circleId} {
      allow read, write: if isAuthenticated() && request.auth.uid == resource.data.ownerId;
    }
  }
}